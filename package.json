{
  "name": "xguard-hook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "forge test",
    "test:node": "node --test scripts/*.test.mjs",
    "build": "forge build && npm run web:build",
    "sol:compile": "node scripts/compile-solidity.mjs",
    "preflight:xlayer": "node scripts/preflight-xlayer.mjs",
    "preflight:xlayer:deploy": "node scripts/preflight-xlayer.mjs --require-private-key",
    "verify:xlayer-deployment": "node scripts/verify-xlayer-deployment.mjs",
    "demo:xlayer:run": "node scripts/run-xlayer-demo.mjs",
    "deploy:xlayer:node": "node scripts/deploy-xlayer.mjs",
    "deploy:xlayer:dry-run": "node scripts/deploy-xlayer.mjs --dry-run",
    "submission:check": "node scripts/submission-check.mjs",
    "submission:check:final": "node scripts/submission-check.mjs --require-deployment",
    "submission:ready": "node scripts/submission-check.mjs --require-deployment --require-links",
    "verify": "npm run test:node && npm run sol:compile && npm run web:build",
    "web:dev": "vite --host 0.0.0.0",
    "web:build": "tsc -b && vite build",
    "web:preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.5.0",
    "@tanstack/react-query": "^5.90.12",
    "@uniswap/v4-core": "^1.0.2",
    "@uniswap/v4-periphery": "^1.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.39.3",
    "wagmi": "^2.19.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "forge-std": "github:foundry-rs/forge-std",
    "solc": "^0.8.35",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
